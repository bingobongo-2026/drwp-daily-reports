# Copy this file to .env to override the defaults used by docker-compose
# and scripts/docker-setup.sh.

# Host port mappings (compose only — container-internal ports are fixed).
WP_PORT=8080
LICENSE_PORT=8001

# Initial WordPress admin (used by scripts/docker-setup.sh on first run).
WP_TITLE=DRWP Demo
WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=adminpass
WP_ADMIN_EMAIL=admin@example.test

# Shared secret for the license server's /admin/* endpoints.
DRWP_ADMIN_TOKEN=demo-token

# Demo license key seeded on first setup.
LICENSE_DEMO_KEY=DEMO-LOCAL
